# This triggers SurveyServiceImpl.applySurvey
POST http://AppConfig.getServerIP()/survey/apply
Content-Type: application/json

{
  "title": "Hygiene Survey",
  "questions": [
    "How was the food?",
    "How was x  the service?",
    "Cleanliness level"
