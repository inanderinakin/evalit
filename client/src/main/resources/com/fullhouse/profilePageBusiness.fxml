<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fullhouse.controllers.ProfilePageBusinessController">
   <children>
      <fx:include source="Sidebar.fxml" />
      <VBox spacing="10.0" HBox.hgrow="ALWAYS">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <HBox spacing="10.0">
               <children>
                  <ImageView fx:id="profilePictureField" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Text fx:id="userNameLabel" strokeType="OUTSIDE" strokeWidth="0.0" text="User Name">
                           <font>
                              <Font name="Nunito ExtraBold" size="24.0" />
                           </font></Text>
                        <Text fx:id="userEmailLabel" strokeType="OUTSIDE" strokeWidth="0.0" text="User Mail">
                           <VBox.margin>
                              <Insets left="10.0" />
                           </VBox.margin></Text>
                        <Text fx:id="userPhoneLabel" strokeType="OUTSIDE" strokeWidth="0.0" text="">
                           <VBox.margin>
                              <Insets left="10.0" />
                           </VBox.margin></Text>
                     </children>
                  </VBox>
               </children>
            </HBox>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Created Surveys" />
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="parentSurveysContainer" fillWidth="true" spacing="10.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
               </content>
            </ScrollPane>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Businesses" />
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="businessesContainer" fillWidth="true" spacing="10.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</HBox>
