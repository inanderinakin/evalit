<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<HBox prefHeight="600.0" prefWidth="820.0"
      stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fullhouse.controllers.SurveyResultsController">

    <fx:include source="Sidebar.fxml" />

    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <VBox fx:id="mainCard" spacing="16.0"
                  style="-fx-background-color: #D9D9D9; -fx-background-radius: 20px; -fx-padding: 24px;">

                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="surveyNameLabel"
                           style="-fx-font-size: 28px;"
                           wrapText="true" HBox.hgrow="ALWAYS" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="surveyIdLabel"
                           style="-fx-font-size: 13px; -fx-text-fill: #555555;" />
                </HBox>

                <HBox alignment="TOP_LEFT" spacing="20.0">
                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label fx:id="businessNameLabel"
                               style="-fx-font-size: 20px;" wrapText="true" />
                        <Label fx:id="addressLabel"
                               style="-fx-font-size: 13px; -fx-underline: true;" wrapText="true" />
                        <Label fx:id="phoneLabel"
                               style="-fx-font-size: 13px; -fx-underline: true;" />
                        <Region prefHeight="6.0" />
                        <Label fx:id="categoriesLabel"
                               style="-fx-font-size: 15px;" wrapText="true" />
                        <Label fx:id="numberOfBusinessesLabel"
                               style="-fx-font-size: 15px;" />
                        <Label fx:id="totalResponsesLabel"
                               style="-fx-font-size: 15px;" />
                    </VBox>

                    <HBox alignment="CENTER" spacing="6.0">
                        <Label text="&#11088;"
                               style="-fx-font-size: 40px;" />
                        <Label fx:id="overallScoreLabel"
                               style="-fx-font-size: 40px;" />
                    </HBox>
                </HBox>

                <VBox fx:id="questionsContainer" spacing="10.0" />

            </VBox>
        </VBox>
    </ScrollPane>
</HBox>
