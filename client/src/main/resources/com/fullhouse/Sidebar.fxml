<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxWidth="-Infinity" minWidth="-Infinity" prefWidth="220.0" spacing="10.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fullhouse.controllers.SidebarController">
   <children>
      <Label text="Eval-it">
         <font>
            <Font size="24.0" />
         </font></Label>
   <Label fx:id="userIdLabel" text="User ID: -" />
      <Button fx:id="btnHome" mnemonicParsing="false" onAction="#handleHome" text="Home" />
      <Button fx:id="btnMarketplace" mnemonicParsing="false" onAction="#handleMarketplace" text="Survey Marketplace" />
      <Button fx:id="btnCreate" mnemonicParsing="false" onAction="#handleCreate" text="Create a Survey" />
      <Button fx:id="btnProfile" mnemonicParsing="false" onAction="#handleProfile" text="Profile" />
      <Button fx:id="btnClaim" mnemonicParsing="false" onAction="#handleClaim" text="Claim your business" />
      <Label text="For Businesses:" />
      <Button fx:id="btnResults" mnemonicParsing="false" onAction="#handleResults" text="Survey Results" />
      <Separator />
      <Region VBox.vgrow="ALWAYS" />
      <Button fx:id="btnSettings" mnemonicParsing="false" onAction="#handleSettings" text="Settings" />
   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</VBox>
