            <ImageView fx:id="businessLogoView" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../images/fillerImage.png" />
               </image></ImageView>
            <VBox prefHeight="150.0" prefWidth="401.0">
               <children>
                  <Text fx:id="businessNameField" strokeType="OUTSIDE" strokeWidth="0.0" text="Business Name" />
                  <Text fx:id="businessAddressField" strokeType="OUTSIDE" strokeWidth="0.0" text="Business Address" />
                  <Text fx:id="businessPhoneNumberField" strokeType="OUTSIDE" strokeWidth="0.0" text="Business Phone Number" />
               </children>
            </VBox>
         </children>
      </HBox>
      <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Applied Surveys:" style="-fx-font-weight: bold; -fx-font-size: 16px;">
      </Text>
      <ScrollPane prefHeight="200.0" prefWidth="200.0" fitToWidth="true">
