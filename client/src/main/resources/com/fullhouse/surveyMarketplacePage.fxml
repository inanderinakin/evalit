<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="800.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fullhouse.controllers.SurveyMarketplaceController">
    <fx:include fx:id="sidebar" source="Sidebar.fxml" />
    <VBox prefHeight="600.0" prefWidth="600.0" spacing="10.0" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
        </padding>
        <children>
            <HBox spacing="10.0">
                <children>
                    <TextField fx:id="searchField" promptText="Search surveys" HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnCategories" mnemonicParsing="false" onAction="#handleCategories" text="Categories" />
                </children>
            </HBox>
            <Label text="Sorting by popularity:" />
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="surveysContainer" spacing="10.0">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                        </padding>
                        <children>
                            <HBox onMouseClicked="#handleSurveyClick" spacing="10.0" styleClass="businessCard">
                                <padding>
                                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                </padding>
                                <children>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label text="Survey Name" />
                                            <Label text="Categories: ..." />
                                            <Label text="Number of uses: 0" />
                                        </children>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </content>
            </ScrollPane>
        </children>
    </VBox>
</HBox>
