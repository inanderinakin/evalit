<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.evalit.LoginController">
   <padding>
      <Insets bottom="40.0" left="80.0" right="80.0" top="40.0" />
   </padding>
   <children>
      <Label alignment="CENTER" text="Welcome to Eval-it!" textAlignment="CENTER">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <TextField fx:id="emailField" promptText="Enter your email:" />
      <PasswordField fx:id="passwordField" promptText="Enter your password" />
      <Button mnemonicParsing="false" onAction="#handleLogin" text="Login" />
      <Label fx:id="messageLabel" textFill="RED" />
   </children>
</VBox>
